# Aptos MPP Environment Configuration
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────────────
# Private key of the server's receiving account (hex, 0x prefixed)
SERVER_PRIVATE_KEY=0x<your-server-private-key>

# Optional: fee-payer account private key for gas sponsorship
FEE_PAYER_PRIVATE_KEY=0x<your-fee-payer-private-key>

# Server's receiving Aptos address
SERVER_ADDRESS=0x<your-server-address>

# ── Client (for demo / integration tests) ────────────────────────────────────
# Private key of the test client account (hex, 0x prefixed)
CLIENT_PRIVATE_KEY=0x<your-client-private-key>

# ── Network ───────────────────────────────────────────────────────────────────
# One of: mainnet | testnet | devnet | localnet
APTOS_NETWORK=testnet

# ── Token ─────────────────────────────────────────────────────────────────────
# Use APT on testnet (coin standard, 8 decimals) for easy faucet funding.
# For USDC on mainnet set ASSET_ADDRESS to the Circle FA address.
ASSET_ADDRESS=
TOKEN_STANDARD=coin
TOKEN_DECIMALS=8
CURRENCY=APT

# Amount to charge per request, in base units (1 APT = 100000000 octas)
CHARGE_AMOUNT=100

# ── Session (payment channels) ───────────────────────────────────────────────
# Address where the aptos_mpp Move contract is deployed.
# Required for session integration tests and MppxSessionServer.registerChannel.
# Deploy: aptos move publish --named-addresses aptos_mpp=<your-addr>
# Init:   aptos move run --function-id <your-addr>::channel::initialize
CHANNEL_MODULE_ADDRESS=0x<your-module-address>

# ── Redis (optional, for production stores) ───────────────────────────────────
# Used when swapping InMemoryStore → RedisStore / InMemoryChannelStore → RedisChannelStore.
REDIS_URL=redis://localhost:6379

# ── Demo server ───────────────────────────────────────────────────────────────
PORT=3000
