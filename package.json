{
  "name": "aptosmpp",
  "version": "0.1.2",
  "description": "Aptos payment method for the Machine Payments Protocol (MPP)",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run tests/unit",
    "test:integration": "node --env-file-if-exists=.env ./node_modules/.bin/vitest run tests/integration --no-file-parallelism",
    "test:all": "vitest run",
    "demo:server": "node --env-file-if-exists=.env ./node_modules/.bin/tsx demo/server/index.ts",
    "demo:client": "node --env-file-if-exists=.env ./node_modules/.bin/tsx demo/client/app.tsx",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^1.33.1",
    "zod": "^3.23.8",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "express": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
